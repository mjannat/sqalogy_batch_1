<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_quality_check_tree" model="ir.ui.view">
        <field name="name">quality.check.tree</field>
        <field name="model">quality.check</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="product_name"/>
                <field name="inspector_id"/>
                <field name="check_date"/>
                <field name="result"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_quality_check_form" model="ir.ui.view">
        <field name="name">quality.check.form</field>
        <field name="model">quality.check</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" string="Confirm" type="object" invisible="state != 'draft'"/>
                    <button name="action_done" string="Complete" type="object" invisible="state != 'confirmed'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <!-- Displaying the generated sequence string as the form header -->
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="product_name"/>
                            <field name="inspector_id"/>
                            <field name="additional_inspector_ids" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="check_date"/>
                            <field name="quantity"/>
                            <field name="result"/>
                        </group>
                    </group>
                    <group>
                        <field name="remarks"/>
                    </group>
                    <notebook>
                        <page string="Product Line">
                            <field name="quantity_lines">
                                <list string="Product Line" editable="bottom">
                                    <field name="product_id"/>
                                    <field name="rec_qty"/>
                                    <field name="damage_qty"/>
                                    <field name="remain_qty"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>

        </field>
    </record>
    <record id="action_quality_check" model="ir.actions.act_window">
        <field name="name">Quality Checks</field>
        <field name="res_model">quality.check</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
